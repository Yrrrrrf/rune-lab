{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable",
      "DOM.AsyncIterable"
    ],
    // Set modern JS target
    "target": "ESNext",
    "module": "ESNext",
    // Resolution & Extensions
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@rune-lab/kernel": [
        "./src/lib/kernel/src/mod.ts"
      ],
      "@rune-lab/layout": [
        "./src/lib/runes/layout/src/mod.ts"
      ],
      "@rune-lab/palettes": [
        "./src/lib/runes/palettes/src/mod.ts"
      ],
      "@rune-lab/money": [
        "./src/lib/runes/plugins/money/src/mod.ts"
      ],
      "@rune-lab/i18n/*": [
        "./src/lib/i18n/*"
      ]
    }
  },
  "exclude": [
    ".*",
    "scripts/**",
    "dist/**",
    "**/*.test.ts"
  ]
}
