{
  "workspace": [
    "./src/core",
    "./src/state",
    "./src/ui"
  ],
  "version": "0.4.0",
  "nodeModulesDir": "manual",
  "tasks": {
    "test": "vp test",
    "test:watch": "vp test watch",
    "i18n": "vp exec paraglide-js compile --project ./src/sdk/ui/src/i18n/project.inlang --outdir ./src/sdk/ui/src/lib/paraglide",
    "build:index": "deno run -A scripts/build-index.ts",
    "build:npm": "deno run -A scripts/build_npm.ts",
    "build:core": "vp pack --cwd src/sdk/core",
    "build:state": "vp pack --cwd src/sdk/state",
    "build:ui": "cd src/sdk/ui && vp exec svelte-kit sync && cd ../../../ && deno task i18n && cd src/sdk/ui && vp exec svelte-package -i src/lib -o ../../../dist/ui",
    "build": "deno task build:core && deno task build:state && deno task build:ui && deno task build:index"
  },
  "imports": {
    "@internal/core": "./src/sdk/core/src/index.ts",
    "@internal/state": "./src/sdk/state/src/index.ts",
    "@internal/ui": "./src/sdk/ui/src/lib/index.ts",
    "rune-lab/core": "./src/sdk/core/src/index.ts",
    "rune-lab/state": "./src/sdk/state/src/index.ts",
    "rune-lab/ui": "./src/sdk/ui/src/lib/index.ts",
    "$lib/": "./src/sdk/ui/src/lib/",
    "daisyui/": "./node_modules/daisyui/",
    "esm-env": "npm:esm-env@^1.2.2",
    "svelte": "npm:svelte@^5.54.1",
    "dinero.js": "npm:dinero.js@^2.0.2",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.55.0",
    "hotkeys-js": "npm:hotkeys-js@^4.0.2",
    "vite": "npm:vite@^8.0.2",
    "vite-plus": "npm:vite-plus",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^7.0.0",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.10",
    "@sveltejs/package": "npm:@sveltejs/package@^2.5.7",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.2",
    "@tailwindcss/forms": "npm:@tailwindcss/forms@^0.5.11",
    "@tailwindcss/typography": "npm:@tailwindcss/typography@^0.5.19",
    "@testing-library/jest-dom": "npm:@testing-library/jest-dom@^6.9.1",
    "@testing-library/svelte": "npm:@testing-library/svelte@^5.3.1",
    "@inlang/paraglide-js": "npm:@inlang/paraglide-js@^2.15.1",
    "jsdom": "npm:jsdom@^29.0.1",
    "publint": "npm:publint@^0.3.18",
    "svelte-check": "npm:svelte-check@^4.4.5",
    "typescript": "npm:typescript@^6.0.2"
  }
}
