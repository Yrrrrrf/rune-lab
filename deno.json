{
  "version": "0.5.0",
  "description": "A comprehensive full-stack application template with Tauri integration",
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yrrrrrf/rune-lab.git"
  },
  "nodeModulesDir": "auto",
  "unstable": [
    "fmt-component"
  ],
  "workspace": [
    "./apps/lab",
    "./src/packages/ui",
    "./src/packages/core",
    "./src/packages/plugins/i18n",
    "./src/packages/plugins/layout",
    "./src/packages/plugins/observer",
    "./src/packages/plugins/palettes"
  ],
  "imports": {
    "vite-plus": "npm:vite-plus"
  },
  "test": {
    "exclude": [
      "apps/**",
      "src/packages/ui/**",
      "src/packages/plugins/**"
    ]
  }
}
