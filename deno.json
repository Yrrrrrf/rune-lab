{
  "name": "yrrrrrf@rune-lab",
  "version": "0.4.1",
  "description": "Modern toolkit for Svelte 5 Runes applications.",
  "type": "module",
  "license": "MIT",
  "author": "Fernando Bryan Reza Campos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yrrrrrf/rune-lab.git"
  },
  "exports": {
    "./core": "./src/core/src/mod.ts",
    "./state": "./src/state/src/mod.ts",
    "./ui": "./src/ui/src/lib/mod.ts"
  },
  "nodeModulesDir": "manual",
  "workspace": [
    "./src/core",
    "./src/state",
    "./src/ui"
  ],
  "tasks": {
    "i18n": "vp exec paraglide-js compile --project ./src/sdk/ui/src/i18n/project.inlang --outdir ./src/sdk/ui/src/lib/paraglide",
    "build:npm": "deno run -A scripts/build_npm.ts"
  },
  "imports": {
    "rune-lab/core": "./src/core/src/mod.ts",
    "rune-lab/state": "./src/state/src/mod.ts",
    "rune-lab/ui": "./src/ui/src/lib/mod.ts",
    "daisyui/": "npm:daisyui",
    "esm-env": "npm:esm-env",
    "svelte": "npm:svelte",
    "dinero.js": "npm:dinero.js",
    "@sveltejs/kit": "npm:@sveltejs/kit",
    "hotkeys-js": "npm:hotkeys-js",
    "vite": "npm:vite",
    "vite-plus": "npm:vite-plus",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static",
    "@sveltejs/package": "npm:@sveltejs/package",
    "@tailwindcss/vite": "npm:@tailwindcss/vite",
    "@tailwindcss/forms": "npm:@tailwindcss/forms",
    "@tailwindcss/typography": "npm:@tailwindcss/typography",
    "@testing-library/jest-dom": "npm:@testing-library/jest-dom",
    "@testing-library/svelte": "npm:@testing-library/svelte",
    "@inlang/paraglide-js": "npm:@inlang/paraglide-js",
    "jsdom": "npm:jsdom",
    "publint": "npm:publint",
    "svelte-check": "npm:svelte-check",
    "typescript": "npm:typescript"
  }
}