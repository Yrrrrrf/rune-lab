{
  "version": "0.5.0-rc.1",
  "description": "A comprehensive full-stack application template with Tauri integration",
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yrrrrrf/rune-lab.git"
  },
  "nodeModulesDir": "auto",
  "unstable": ["fmt-component"],
  "workspace": [
    "./apps/lab",
    "./src/packages/ui",
    "./src/packages/core",
    "./src/packages/plugins/i18n",
    "./src/packages/plugins/layout",
    "./src/packages/plugins/observer",
    "./src/packages/plugins/palettes"
  ],
  "imports": {
    "svelte": "npm:svelte@^5",
    "vite": "npm:vite",
    "vite-plus": "npm:vite-plus",
    "typescript": "npm:typescript@6",
    "jsdom": "npm:jsdom",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte",
    "@testing-library/jest-dom": "npm:@testing-library/jest-dom",
    "effect": "npm:effect@^3",
    "esm-env": "npm:esm-env@^1"
  },
  "test": {
    "exclude": ["apps/**", "src/packages/ui/**", "src/packages/plugins/**"]
  }
}
