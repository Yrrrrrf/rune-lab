{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": [
      "svelte"
    ]
  },
  "include": [
    "src"
  ]
}
