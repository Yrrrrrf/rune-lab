{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable",
      "DOM.AsyncIterable"
    ],
    // Set modern JS target
    "target": "ESNext",
    "module": "ESNext",
    // Resolution & Extensions
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "exclude": [
    ".*",
    "scripts/**",
    "dist/**",
    "**/*.test.ts"
  ]
}
